SHARED_VLESS_URI=vless://b2602dee-0bc7-4c07-b451-28713dfcd938@195.133.198.70:443?security=reality&encryption=none&type=tcp&sni=www.yandex.ru&fp=chrome&pbk=5Pnz2ZrT5eLlyAi5Qs8lmpzCM3RIffiC2fFAWcoJbXA&sid=5a131c07e1f2b15f&flow=xtls-rprx-vision#RUVDS-Hostkey

# HTTP-клиент к панели 3x-ui (см. config/panels.php)
PANEL_HTTP_TIMEOUT=30
PANEL_HTTP_CONNECT_TIMEOUT=10
PANEL_VERIFY_SSL=true
PANEL_HTTP_RETRY=2
PANEL_LOGIN_PATH=/login
PANEL_ADD_CLIENT_PATH=/panel/api/inbounds/addClient
PANEL_UPDATE_CLIENT_PATH=/panel/api/inbounds/updateClient
PANEL_CLIENT_TRAFFIC_PATH=/panel/api/inbounds/getClientTraffics

# Админка (/admin) — без этого вход заблокирован
ADMIN_LOGIN=
ADMIN_PASSWORD=

# УСТАРЕЛО: тестовая панель 3x-ui (админка теперь работает через trial_keys в БД)
# TEST_PANEL_URL=
# TEST_PANEL_USERNAME=
# TEST_PANEL_PASSWORD=
# TEST_PANEL_SERVER_IP=

# YooKassa payment
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# YOOKASSA_RETURN_URL=  # опционально: свой URL/путь возврата; иначе /cabinet

# API для Telegram-бота и внешних клиентов (заголовок X-Api-Token или Bearer)
API_TOKEN=

# Telegram Bot — для push-уведомлений (оплата получена) из webhook'а YooKassa.
# TELEGRAM_BOT_TOKEN получается у @BotFather. TELEGRAM_BOT_USERNAME (без @) —
# используется как return_url YooKassa, чтобы юзер после оплаты возвращался в чат.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Чат (или группа) куда бот шлёт уведомления о тикетах поддержки.
# Бот должен быть участником чата. Если пусто — пуши не отправляются.
SUPPORT_ADMIN_TELEGRAM_CHAT_ID=

# Подписи узлов Happ: «AVA 🇳🇱 Нидерланды» (опционально)
HAPP_BRAND=AVA

# Если в тарифе traffic_gb=0, в subscription-userinfo показывается этот объём (ГБ). 0 = безлимит.
# DEFAULT_RETAIL_TRAFFIC_GB=100

# Единая Hysteria2-ссылка для всех платных подписок и триала (Blitz — один пользователь).
# SHARED_HY2_URI=hy2://user:pass@host:443?obfs=salamander&obfs-password=...&pinSHA256=...&insecure=1#Label

# ===== УСТАРЕЛО: мульти-ноды / 3x-ui (не используется) =====
# ===== Общие параметры подписки (модель «одна подписка для всех») =====
# Один UUID/пароль на всю инфру, контроль срока — на стороне сайта (/sub/{sub_id} -> 403 после expires_at).
SHARED_VLESS_UUID=
SHARED_REALITY_PBK=
SHARED_REALITY_SID=
SHARED_REALITY_SNI=www.cloudflare.com
SHARED_REALITY_FP=chrome
SHARED_REALITY_FLOW=xtls-rprx-vision
SHARED_HYSTERIA_PASSWORD=
SHARED_HYSTERIA_OBFS_PASSWORD=
SHARED_HYSTERIA_OBFS=salamander
# self-signed cert на IP -- клиент пропускает TLS-валидацию (1). С реальным доменом ставить 0.
SHARED_HYSTERIA_INSECURE=1

