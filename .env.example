APP_NAME=Laravel
APP_BRAND_NAME=AVA
APP_BRAND_SUFFIX=VPN
TELEGRAM_SUPPORT_URL=https://t.me/avavpn_ru
TELEGRAM_CHANNEL_URL=https://t.me/avavpn_ru
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Дополнительные запрещённые домены почты (одноразовые), через запятую. Базовый список — в config/disposable_email.php
# BLOCKED_EMAIL_DOMAINS=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="support@avavpn.ru"
MAIL_FROM_NAME="AVA VPN Support"
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# HTTP-клиент к панели 3x-ui (см. config/panels.php)
PANEL_HTTP_TIMEOUT=30
PANEL_HTTP_CONNECT_TIMEOUT=10
PANEL_VERIFY_SSL=true
PANEL_HTTP_RETRY=2
PANEL_LOGIN_PATH=/login
PANEL_ADD_CLIENT_PATH=/panel/api/inbounds/addClient
PANEL_UPDATE_CLIENT_PATH=/panel/api/inbounds/updateClient
PANEL_CLIENT_TRAFFIC_PATH=/panel/api/inbounds/getClientTraffics

# Админка (/admin) — без этого вход заблокирован
ADMIN_LOGIN=
ADMIN_PASSWORD=

# Тестовая панель 3x-ui (админка → тестовые ключи)
TEST_PANEL_URL=
TEST_PANEL_USERNAME=
TEST_PANEL_PASSWORD=
TEST_PANEL_SERVER_IP=
# TEST_PANEL_INBOUND_ID=1

# YooKassa payment
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# YOOKASSA_RETURN_URL=  # опционально: свой URL/путь возврата; иначе /cabinet

# API для Telegram-бота и внешних клиентов (заголовок X-Api-Token или Bearer)
API_TOKEN=

# Telegram Bot — для push-уведомлений (оплата получена) из webhook'а YooKassa.
# TELEGRAM_BOT_TOKEN получается у @BotFather. TELEGRAM_BOT_USERNAME (без @) —
# используется как return_url YooKassa, чтобы юзер после оплаты возвращался в чат.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Чат (или группа) куда бот шлёт уведомления о тикетах поддержки.
# Бот должен быть участником чата. Если пусто — пуши не отправляются.
SUPPORT_ADMIN_TELEGRAM_CHAT_ID=

# Подписи узлов Happ: «AVA 🇳🇱 Нидерланды» (опционально)
HAPP_BRAND=AVA

# Если в тарифе traffic_gb=0, в subscription-userinfo показывается этот объём (ГБ). 0 = безлимит.
# DEFAULT_RETAIL_TRAFFIC_GB=100

# ===== Общие параметры подписки (модель «одна подписка для всех») =====
# Один UUID/пароль на всю инфру, контроль срока — на стороне сайта (/sub/{sub_id} -> 403 после expires_at).
SHARED_VLESS_UUID=
SHARED_REALITY_PBK=
SHARED_REALITY_SID=
SHARED_REALITY_SNI=www.cloudflare.com
SHARED_REALITY_FP=chrome
SHARED_REALITY_FLOW=xtls-rprx-vision
SHARED_HYSTERIA_PASSWORD=
SHARED_HYSTERIA_OBFS_PASSWORD=
SHARED_HYSTERIA_OBFS=salamander

# ===== Узлы подписки =====
# A: yandex entry с WG-egress в NL (только VLESS)
NODE_A_HOST=158.160.229.195
NODE_A_VLESS_PORT=443
NODE_A_HAPP_LABEL=🇳🇱 Нидерланды

# C: NL standalone (только VLESS)
NODE_C_HOST=82.23.162.45
NODE_C_VLESS_PORT=443
NODE_C_HAPP_LABEL=🇳🇱 Нидерланды Direct

# D: FR standalone (только Hysteria2)
NODE_D_HOST=82.22.50.114
NODE_D_HYSTERIA_PORT=8443
NODE_D_HAPP_LABEL=🇫🇷 Франция

# E: новый узел (VLESS + Hysteria2)
NODE_E_HOST=185.214.108.78
NODE_E_VLESS_PORT=443
NODE_E_HYSTERIA_PORT=8443
NODE_E_VLESS_HAPP_LABEL=🌐 Резерв VLESS
NODE_E_HYSTERIA_HAPP_LABEL=🌐 Резерв Hysteria

# ===== Триал =====
# Срок (часы) и soft-лимит трафика (ГБ, информационно — не блочит).
TRIAL_DURATION_HOURS=3
TRIAL_SOFT_QUOTA_GB=5

# ===== УСТАРЕЛО: панели 3x-ui (оставлено для админки до полного отказа) =====
SALE_PANEL_1_HAPP_LABEL=
SALE_PANEL_2_HAPP_LABEL=
TEST_PANEL_HAPP_LABEL=
SALE_PANEL_1_URL=
SALE_PANEL_1_USERNAME=
SALE_PANEL_1_PASSWORD=
SALE_PANEL_2_URL=
SALE_PANEL_2_USERNAME=
SALE_PANEL_2_PASSWORD=
SALE_PANEL_1_SERVER_IP=158.160.229.195
SALE_PANEL_2_SERVER_IP=158.160.249.138

# IndexNow — мгновенная отправка URL в поисковики (Яндекс, Bing, Naver).
# Ключ должен совпадать с именем файла, отдаваемого по /<key>.txt.
# Если оставить пустым, ключ генерируется автоматически из APP_KEY.
INDEXNOW_KEY=
